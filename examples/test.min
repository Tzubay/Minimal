fn INE(edad) {
    if (edad < 18) {
        let restante = 18 - edad;
        return "No puedes tramitar tu INE, te faltan: ", restante, " años para hacerlo";
    }
    else {
        return "Puedes tramitar tu INE, pasa";
    }
}

let nombre = input("Escribe tu nombre: ");
let edad = input("Escribe tu edad: ");

print "Te llamas ", nombre, " y ", INE(edad);