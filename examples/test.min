fn suma(a, b) {
    return a + b;
}

fn saludar(nombre) {
    return "Hola " + nombre;
}

fn obtenerValor(matriz, fila, columna) {
    return matriz[fila][columna];
}

let resultado = suma(10, 5);
print resultado;

print suma(3, 4);
print saludar("Minimal");

let matriz = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
];

print obtenerValor(matriz, 2, 1);