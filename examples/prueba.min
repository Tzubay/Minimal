fn tarea(nombre, veces) {
    for (let i = 0; i < veces; i = i + 1) {
        print nombre, " -> ", i;
        sleep(300);
    }

    return "terminado";
}

let h1 = thread(tarea, "Hilo A", 3);
let h2 = thread(tarea, "Hilo B", 3);

start(h1);
start(h2);

join(h1);
join(h2);

print "Programa terminado";